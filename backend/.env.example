# Copia a .env y ajusta en producción
NODE_ENV=development
PORT=3000

# Ruta del archivo SQLite (en Docker apúntala a un volumen persistente)
DB_PATH=./data/iaas.sqlite

# ¡OBLIGATORIO en producción! Genera uno con: openssl rand -base64 48
JWT_SECRET=dev-insecure-secret-change-me

# Endpoint POST /api/seed (datos de ejemplo). Ponlo en "false" en producción.
ENABLE_DEV_SEED=true
